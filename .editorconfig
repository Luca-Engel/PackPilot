root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 120
tab_width = 4

[*.{kt,kts}]
# Function naming: Disabled to allow Composable functions starting with uppercase
ktlint_standard_function-naming = disabled
# Wildcard imports: Disabled as requested
ktlint_standard_no-wildcard-imports = disabled
